# ── Database ───────────────────────────────────────────────────────────────
# Postgres (default). Matches docker-compose.yml.
DATABASE_URL="postgresql://pasa:pasa_password@localhost:5432/pasa_election?schema=public"

# To use MySQL instead: set provider="mysql" in prisma/schema.prisma and use:
# DATABASE_URL="mysql://pasa:pasa_password@localhost:3306/pasa_election"

# ── Auth ───────────────────────────────────────────────────────────────────
# Secret used to sign session JWTs. CHANGE THIS in production (min 32 chars).
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ── Seed accounts (created by `pnpm db:seed`) ──────────────────────────────
ADMIN_EMAIL="admin@oyscatech.edu.ng"
ADMIN_PASSWORD="ChangeMe!Admin2026"
OBSERVER_EMAIL="observer@oyscatech.edu.ng"
OBSERVER_PASSWORD="ChangeMe!Observer2026"
